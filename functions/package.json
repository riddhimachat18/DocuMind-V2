{
  "name": "functions",
  "main": "lib/index.js",
  "scripts": {
    "lint": "eslint .",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "start:classify": "node lib/classifySnippet.js",
    "start:generate": "node lib/generateBrd.js",
    "start:detect": "node lib/detectConflicts.js",
    "start:resolve": "node lib/onConflictResolved.js",
    "start:chat": "node lib/onChatMessage.js",
    "start:upload": "node lib/uploadTranscript.js"
  },
  "engines": {
    "node": "24"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@google/generative-ai": "^0.24.1",
    "@types/busboy": "^1.5.4",
    "busboy": "^1.6.0",
    "chromadb": "^3.3.1",
    "express": "^4.22.1",
    "firebase-admin": "^13.6.0",
    "firebase-functions": "^7.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@typescript-eslint/eslint-plugin": "^5.12.0",
    "@typescript-eslint/parser": "^5.12.0",
    "eslint": "^8.9.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-import": "^2.25.4",
    "firebase-functions-test": "^3.4.1",
    "typescript": "^5.7.3"
  },
  "private": true
}
